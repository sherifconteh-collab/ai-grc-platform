{
  "name": "controlweave-frontend",
  "version": "4.2.2",
  "license": "AGPL-3.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "node -e \"const fs=require('fs');if(fs.existsSync('server.js')){require('./server.js')}else{const c=require('child_process');const cmd=process.platform==='win32'?'npx.cmd':'npx';const p=c.spawn(cmd,['next','start'],{stdio:'inherit'});p.on('exit',code=>process.exit(code??1));}\"",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "e2e": "playwright test",
    "e2e:install": "playwright install --with-deps chromium",
    "generate:api-types": "openapi-typescript ../docs/openapi.yaml -o src/lib/generated/api-types.ts",
    "postinstall": "node scripts/postinstall-ajv-compat.js && node scripts/patch-eslint-ajv.js"
  },
  "dependencies": {
    "@simplewebauthn/browser": "^13.2.2",
    "axios": "^1.16.1",
    "date-fns": "^4.1.0",
    "lucide-react": "^1.16.0",
    "next": "16.2.7",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "recharts": "^2.15.4",
    "socket.io-client": "^4.8.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.0.0",
    "eslint": "^10.2.1",
    "eslint-config-next": "^16.2.6",
    "openapi-typescript": "^7.10.1",
    "tailwindcss": "^4.3.0",
    "typescript": "6.0.3"
  },
  "overrides": {
    "minimatch": "^10.2.3",
    "socket.io-parser": "4.2.6",
    "follow-redirects": "^1.16.0",
    "postcss": "^8.5.10",
    "fast-uri": ">=3.1.2",
    "brace-expansion": ">=5.0.6",
    "ws": ">=8.20.2",
    "form-data": ">=4.0.6",
    "@babel/core": "^7.29.7",
    "js-yaml": ">=4.2.0"
  }
}
