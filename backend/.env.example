# Database Configuration
DATABASE_URL=postgresql://username:password@localhost:5432/ai_grc_platform

# Server Configuration
PORT=3001
NODE_ENV=development

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-minimum-32-characters-long-change-in-production
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Password Security
BCRYPT_ROUNDS=12

# CORS Configuration
CORS_ORIGIN=http://localhost:3000

# Frontend URL (for password reset emails)
FRONTEND_URL=http://localhost:3000

# Email Configuration (for password reset)
# Using Gmail as example - you can use any SMTP service
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-specific-password
EMAIL_FROM=noreply@yourdomain.com

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_AUTH=5
RATE_LIMIT_MAX_API=100

# License Key (optional)
# Set LICENSE_KEY to a ControlWeave-issued license key to unlock Pro/Enterprise features.
# Set LICENSE_SECRET to the signing secret provided by ControlWeave (required for key validation).
# If not set, the application runs in Community Edition mode.
# LICENSE_KEY=v1.<base64url-payload>.<hmac-hex>
# LICENSE_SECRET=your-license-signing-secret

# AI / LLM Configuration (BYOK — Bring Your Own Key)
# Configure at least one provider for AI features (gap analysis, policy generation, etc.).
# Users can also configure keys per-organization via Settings > LLM Configuration in the UI.
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# GEMINI_API_KEY=AIza...
# GROQ_API_KEY=gsk_...
# XAI_API_KEY=xai-...
# OLLAMA_BASE_URL=http://localhost:11434

# Platform Admin (auto-provisioned on first startup)
# Set these to create a platform admin account automatically.
# PLATFORM_ADMIN_EMAIL=admin@example.com
# PLATFORM_ADMIN_PASSWORD=your-secure-password-min-12-chars
# PLATFORM_ADMIN_FIRST_NAME=Platform
# PLATFORM_ADMIN_LAST_NAME=Admin
# PLATFORM_ADMIN_ORG=My Organization
